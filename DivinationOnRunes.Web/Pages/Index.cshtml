@page
@model IndexModel
@{
    ViewData["Title"] = "Гадание на рунах";
}

<div class="text-center">
    <h1 class="display-4">Гадание на рунах</h1>
    <p class="lead text-muted">Старший Футарк</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <form method="post" class="card p-4 shadow-sm">
            <div class="mb-3">
                <label asp-for="Question" class="form-label">Введи свой вопрос</label>
                <input asp-for="Question" class="form-control" placeholder="О чём ты хочешь узнать?" />
                <span asp-validation-for="Question" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SpreadType" class="form-label">Тип расклада</label>
                <select asp-for="SpreadType" class="form-select">
                    <option value="@DivinationOnRunes.Core.SpreadType.Answer">
                        Ответ на вопрос (одна руна)
                    </option>
                    <option value="@DivinationOnRunes.Core.SpreadType.PastPresentFuture">
                        Прошлое, настоящее, будущее
                    </option>
                    <option value="@DivinationOnRunes.Core.SpreadType.SituationObstacleAdvice">
                        Ситуация, препятствие, совет
                    </option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary btn-lg">
                Бросить руны
            </button>
        </form>

        @if (Model.Result != null)
        {
            <div class="card mt-4 p-4 shadow-sm">
                <h2 class="h4 mb-3">Результат</h2>
                <p class="text-muted">
                    <strong>Вопрос:</strong> @Model.Result.Question
                </p>
                <p class="text-muted small">
                    @Model.Result.Timestamp.ToString("dd.MM.yyyy HH:mm")
                </p>
                <hr />

                @foreach (var position in Model.Result.Runes)
                {
                    <div class="mb-3">
                        <h3 class="h5">
                            <span style="font-size: 2rem;">@position.Rune.Symbol</span>
                            @position.Position — @position.Rune.Name
                            @if (position.IsReversed && position.Rune.IsReversible)
                            {
                                <span class="badge bg-secondary">перевёрнутая</span>
                            }
                        </h3>
                        <p class="text-muted mb-1">
                            <em>@position.Rune.ShortMeaning</em>
                        </p>
                        <p>@position.GetMeaning()</p>
                    </div>
                }
            </div>
        }
    </div>
</div>